#include <stdio.h>
#include <string.h>

long long factorial(int n) {
    long long fact = 1;
    for (int i = 2; i <= n; i++) {
        fact *= i;
    }
    return fact;
}
int main() {
    char word[20];
    int count[256] = {0}; 

    printf("Введіть слово: ");
    if (scanf("%19s", word) != 1) {
        return 0;
    }
    int n = strlen(word);

    for (int i = 0; i < n; i++) {
        count[(unsigned char)word[i]]++;
    }
    long long numerator = factorial(n);
    long long denominator = 1;
    for (int i = 0; i < 256; i++) {
        if (count[i] > 1) {
            denominator *= factorial(count[i]);
        }
    }
    long long total_anagrams = numerator / denominator;
    printf("Кількість анаграм: %lld\n", total_anagrams);
    return 0;
}
