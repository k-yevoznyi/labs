#include <stdio.h>

int main() {
    int p;
    if (scanf("%d", &p) != 1) {
        return 0;
    }
    if (p == 1) {
        printf("2\n");
        return 0;
    }
    if (p == 2) {
        printf("4\n");
        return 0;
    }
    long long f[31];
    f[1] = 2;
    f[2] = 4;

    for (int i = 3; i <= p; i++) {
        f[i] = f[i - 1] + f[i - 2];
    }
    printf("%lld\n", f[p]);
    return 0;
}
