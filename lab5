#include <stdio.h>

int main() {
    int n;
    const int MOD = 12345;

    printf("Введіть довжину послідовності n: ");
    if (scanf("%d", &n) != 1 || n <= 1) {
        return 0;
    }
    int f1 = 2; 
    int f2 = 4; 
    int f3 = 7;

    if (n == 2) {
        printf("Кількість шуканих послідовностей: %d\n", f2 % MOD);
        return 0;
    }
    if (n == 3) {
        printf("Кількість шуканих послідовностей: %d\n", f3 % MOD);
        return 0;
    }
    int current_f = 0;
    
    for (int i = 4; i <= n; i++) {
        current_f = (f3 + f2 + f1) % MOD;
        f1 = f2;
        f2 = f3;
        f3 = current_f;
    }
    printf("Кількість шуканих послідовностей: %d\n", f3);
    return 0;
}
